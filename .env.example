# Optional UiPath auth and environment defaults for repo-local operations.
#
# scripts/uipath_auth.sh defaults to interactive desktop/browser auth.
# Pass --unattended only when you explicitly want to mint a token from
# client credentials.
#
# The repo's Shared-folder operation scripts prefer desktop auth cache first,
# then fall back to unattended client credentials when those env vars are
# configured.
#
# Leave the client credential fields blank unless you intentionally want
# unattended auth for CI or scripted cloud operations.

# Interactive auth defaults.
UIPATH_ENVIRONMENT=cloud
UIPATH_TENANT=HLS_SE_Team
UIPATH_URL=https://cloud.uipath.com/uipathlabs/HLS_SE_Team
UIPATH_FOLDER_PATH=Shared

# Unattended auth inputs.
UIPATH_BASE_URL=https://cloud.uipath.com/uipathlabs/HLS_SE_Team
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=
UIPATH_SCOPE=
